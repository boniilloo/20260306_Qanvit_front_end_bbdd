# Supabase (proyecto nuevo: https://bymbfjkezrwsuvbsaycg.supabase.co)
# Obtén la anon key en: Dashboard → Settings → API → anon public
VITE_USE_LOCAL_SUPABASE=false
VITE_SUPABASE_URL=https://bymbfjkezrwsuvbsaycg.supabase.co
VITE_SUPABASE_ANON_KEY=

# Backend WebSocket (agents). Candidates chat uses same host with path /ws-rfx-candidates
# Production: wss://<your-api-host>/ws-rfx-agent
VITE_WS_RFX_AGENT_URL=
# Local dev (optional override)
# VITE_WS_RFX_AGENT_LOCAL_URL=ws://localhost:8000/ws-rfx-agent

# Optional: HTTP base for REST endpoints (e.g. POST /api/rfxs/bootstrap-from-intent).
# If unset, derived from the WebSocket URL above (ws→http, strip /ws-rfx-agent).
# VITE_RFX_API_HTTP_URL=http://localhost:8000
