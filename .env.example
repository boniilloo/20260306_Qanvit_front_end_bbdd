# Supabase (proyecto nuevo: https://bymbfjkezrwsuvbsaycg.supabase.co)
# Obtén la anon key en: Dashboard → Settings → API → anon public
VITE_USE_LOCAL_SUPABASE=false
VITE_SUPABASE_URL=https://bymbfjkezrwsuvbsaycg.supabase.co
VITE_SUPABASE_ANON_KEY=

# Backend WebSocket (agents)
# Production (Vercel): REQUIRED
# Example: wss://<your-railway-backend>/ws-rfx-agent
VITE_WS_RFX_AGENT_URL=
# Local development override (optional; defaults to ws://localhost:8000/ws-rfx-agent)
# VITE_WS_RFX_AGENT_LOCAL_URL=ws://localhost:8000/ws-rfx-agent

# Optional: explicit HTTP base for REST endpoints (e.g. POST /api/rfxs/bootstrap-from-intent).
# If unset, it is derived from the WebSocket URL above (ws→http, strip /ws-rfx-agent).
# VITE_RFX_API_HTTP_URL=http://localhost:8000
